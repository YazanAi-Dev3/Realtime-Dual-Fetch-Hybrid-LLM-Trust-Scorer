# ============================================================
# .env.example — Copy this file to .env and fill in your keys
# ============================================================

# --- Google Gemini AI (used by the Analyzer Engine) ---
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Firecrawl (used for clean Markdown scraping) ---
# Get your key at: https://www.firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# --- Ollama (local LLM server for the Chatbot Engine) ---
# Default assumes Ollama is running locally. No key needed.
# Download Ollama at: https://ollama.com/
OLLAMA_BASE_URL=http://localhost:11434/api/chat
OLLAMA_MODEL_NAME=gemma3:4b

# --- Server Configuration ---
SERVER_PORT=8000
